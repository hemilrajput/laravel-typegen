{
    "name": "hemilrajput/laravel-typegen",
    "description": "Generate TypeScript types from Eloquent models, Enums & FormRequests.",
    "keywords": ["laravel", "typescript", "inertia", "eloquent", "types", "codegen"],
    "license": "MIT",
    "authors": [
        { "name": "Hemil Rajput", "email": "rajputhemil04@gmail.com" }
    ],
    "require": {
        "php": "^8.2|^8.3|^8.4",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "laravel/pint": "^1.29",
        "larastan/larastan": "^3.9|^4.0",
        "rector/rector": "^2.4",
        "driftingly/rector-laravel": "^2.5"
    },
    "autoload": {
        "psr-4": {
            "Hemilrajput\\TypeGen\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hemilrajput\\TypeGen\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "2.x-dev"
        },
        "laravel": {
            "providers": [
                "Hemilrajput\\TypeGen\\TypeGenServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test:coverage": "vendor/bin/pest --coverage",
        "lint": "vendor/bin/pint",
        "lint:test": "vendor/bin/pint --test",
        "stan": "vendor/bin/phpstan analyse --memory-limit=2G",
        "rector": "vendor/bin/rector process --dry-run",
        "rector:fix": "vendor/bin/rector process"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "support": {
        "issues": "https://github.com/hemilrajput/laravel-typegen/issues",
        "source": "https://github.com/hemilrajput/laravel-typegen"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "platform-check": false
    }
}
