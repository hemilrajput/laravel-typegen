{
    "name": "hemilrajput/laravel-typegen",
    "description": "Generate TypeScript types from Eloquent models, Enums & FormRequests.",
    "keywords": ["laravel", "typescript", "inertia", "eloquent", "types", "codegen"],
    "license": "MIT",
    "authors": [
        { "name": "Hemil Rajput", "email": "rajputhemil04@gmail.com" }
    ],
    "require": {
        "php": "^8.2|^8.3|^8.4",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "laravel/pint": "^1.29",
        "larastan/larastan": "^3.9"
    },
    "autoload": {
        "psr-4": {
            "Hemilrajput\\TypeGen\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hemilrajput\\TypeGen\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Hemilrajput\\TypeGen\\TypeGenServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/pest"
    },
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "platform-check": false
    }
}
