{
    "name": "laravel-typegen",
    "displayName": "Laravel TypeGen",
    "description": "Auto-run php artisan typescript:generate on save for models tagged with #[TypeScript].",
    "version": "0.1.0",
    "publisher": "hemilrajput",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/hemilrajput/laravel-typegen"
    },
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": ["Other"],
    "keywords": ["laravel", "typescript", "eloquent", "inertia", "codegen"],
    "activationEvents": [
        "workspaceContains:artisan"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "configuration": {
            "title": "Laravel TypeGen",
            "properties": {
                "laravelTypegen.phpPath": {
                    "type": "string",
                    "default": "php",
                    "description": "Path to the PHP executable."
                },
                "laravelTypegen.artisanCommand": {
                    "type": "string",
                    "default": "typescript:generate",
                    "description": "Artisan command to run on save."
                },
                "laravelTypegen.enableOnSave": {
                    "type": "boolean",
                    "default": true,
                    "description": "Automatically run type generation when a PHP file with #[TypeScript] is saved."
                },
                "laravelTypegen.showOutputChannel": {
                    "type": "boolean",
                    "default": false,
                    "description": "Show the output channel when type generation runs."
                }
            }
        },
        "commands": [
            {
                "command": "laravelTypegen.generate",
                "title": "Laravel TypeGen: Generate Types Now"
            },
            {
                "command": "laravelTypegen.toggle",
                "title": "Laravel TypeGen: Toggle Auto-Generate on Save"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "lint": "eslint src --ext ts"
    },
    "devDependencies": {
        "@types/vscode": "^1.85.0",
        "@types/node": "^20.0.0",
        "typescript": "^5.3.0",
        "@typescript-eslint/eslint-plugin": "^7.0.0",
        "@typescript-eslint/parser": "^7.0.0",
        "eslint": "^8.57.0"
    }
}
